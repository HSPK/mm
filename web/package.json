    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.30.3",
    "react-zoom-pan-pinch": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "vidstack": "^1.12.13",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
